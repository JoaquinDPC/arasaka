# --- Scraper behaviour ---
DEBUG=false
SCRAPER_HEADLESS_MODE=false
SCRAPER_DEFAULT_TIMEOUT=15000
SCRAPER_SLOW_MO=100
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/108.0.0.0 Safari/537.36
SCRAPER_VIEWPORT_WIDTH=1366
SCRAPER_VIEWPORT_HEIGHT=768
SCRAPER_LOCALE=es-CL
SCRAPER_TIMEZONE_ID=America/Santiago
SCRAPER_MIN_HUMAN_DELAY_MS=200
SCRAPER_MAX_HUMAN_DELAY_MS=800
